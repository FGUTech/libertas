{
  "name": "libertas",
  "version": "0.1.0",
  "description": "Automated research and publishing platform for Freedom Tech",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:golden": "vitest run tests/golden",
    "lint": "eslint src tests --ext .ts",
    "lint:fix": "eslint src tests --ext .ts --fix",
    "format": "prettier --write 'src/**/*.ts' 'tests/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.ts' 'tests/**/*.ts'",
    "typecheck": "tsc --noEmit",
    "validate:schemas": "tsx scripts/validate-schemas.ts",
    "generate:feeds": "tsx scripts/generate-feeds.ts",
    "db:migrate": "tsx scripts/migrate.ts"
  },
  "keywords": [
    "freedom-tech",
    "bitcoin",
    "privacy",
    "censorship-resistance",
    "automation"
  ],
  "author": "FGU (Freedom Go Up)",
  "license": "MIT",
  "dependencies": {
    "ajv": "^8.12.0",
    "ajv-formats": "^2.1.1",
    "cheerio": "^1.0.0-rc.12",
    "crypto-js": "^4.2.0",
    "date-fns": "^3.3.1",
    "dotenv": "^16.4.1",
    "fast-xml-parser": "^4.3.4",
    "feed": "^4.2.2",
    "gray-matter": "^4.0.3",
    "node-fetch": "^3.3.2",
    "pg": "^8.11.3",
    "rss-parser": "^3.13.0",
    "slugify": "^1.6.6",
    "uuid": "^9.0.1",
    "yaml": "^2.3.4",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/crypto-js": "^4.2.2",
    "@types/node": "^20.11.16",
    "@types/pg": "^8.11.0",
    "@types/uuid": "^9.0.8",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.2.4",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^1.2.2"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
