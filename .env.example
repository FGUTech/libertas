# FGU Signal Engine - Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# =============================================================================
# REQUIRED - Core Infrastructure
# =============================================================================

# PostgreSQL connection string
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://fgu:password@localhost:5432/fgu_signal_engine

# n8n webhook base URL (for receiving callbacks)
N8N_WEBHOOK_URL=https://n8n.your-domain.com/webhook

# LLM API configuration
# Supported providers: anthropic, openai
LLM_PROVIDER=anthropic
LLM_API_KEY=your-api-key-here
LLM_MODEL=claude-3-5-sonnet-20241022

# GitHub token for creating issues and PRs
# Required scopes: repo, issues, pull_requests
GITHUB_TOKEN=ghp_your-github-token

# GitHub organization/repo for issues
GITHUB_ORG=your-org
GITHUB_REPO=fgu-signal-engine

# =============================================================================
# OPTIONAL - Object Storage
# =============================================================================

# S3-compatible object storage for raw content
# If not set, raw content will not be stored
OBJECT_STORAGE_ENDPOINT=https://s3.your-provider.com
OBJECT_STORAGE_ACCESS_KEY=your-access-key
OBJECT_STORAGE_SECRET_KEY=your-secret-key
OBJECT_STORAGE_BUCKET=fgu-raw-content
OBJECT_STORAGE_REGION=auto

# =============================================================================
# OPTIONAL - Email (Newsletter)
# =============================================================================

# SMTP configuration for sending newsletters
SMTP_HOST=smtp.your-provider.com
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
SMTP_FROM=signals@fgu.tech

# Listmonk configuration (if using Listmonk for newsletters)
LISTMONK_URL=https://listmonk.your-domain.com
LISTMONK_USER=admin
LISTMONK_PASS=your-listmonk-password

# =============================================================================
# OPTIONAL - Vector Store (Semantic Deduplication)
# =============================================================================

# pgvector connection (if different from main DB)
# If not set, semantic deduplication is disabled
VECTOR_DB_URL=postgresql://fgu:password@localhost:5432/fgu_vectors

# Or use Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=your-qdrant-api-key

# =============================================================================
# OPTIONAL - Notifications
# =============================================================================

# Slack webhook for notifications
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz

# Discord webhook for notifications
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxx/yyy

# Matrix room for notifications
MATRIX_HOMESERVER=https://matrix.org
MATRIX_ACCESS_TOKEN=your-matrix-token
MATRIX_ROOM_ID=!roomid:matrix.org

# =============================================================================
# OPTIONAL - Site Publishing
# =============================================================================

# Git repository for site content
SITE_REPO_URL=git@github.com:your-org/fgu-tech.git
SITE_REPO_BRANCH=main
SITE_CONTENT_PATH=content/signals

# Base URL for published content
SITE_BASE_URL=https://fgu.tech

# =============================================================================
# OPTIONAL - Performance & Monitoring
# =============================================================================

# Sentry DSN for error tracking
SENTRY_DSN=https://xxx@sentry.io/yyy

# Log level (debug, info, warn, error)
LOG_LEVEL=info

# Request timeout in milliseconds
REQUEST_TIMEOUT_MS=30000

# =============================================================================
# DEVELOPMENT
# =============================================================================

# Set to 'development' for local development
NODE_ENV=production

# Enable debug mode for n8n workflows
N8N_DEBUG=false
