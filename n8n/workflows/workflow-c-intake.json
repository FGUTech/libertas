      "parameters": {
        "operation": "executeQuery",
        "query": "UPDATE submissions\n  SET tags = ARRAY(SELECT json_array_elements_text($1::json)),\n      risk_level = $2,\n      status = 'triaged'\n  WHERE id = $3::uuid",
        "options": {
          "queryReplacement": "={{ JSON.stringify($json.tags) }}, {{ $json.risk_level }}, {{ $json.submissionId }}"
        }
