        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"claude-sonnet-4-20250514\",\n  \"max_tokens\": 512,\n  \"messages\": [{\n    \"role\": \"user\",\n    \"content\": \"Classify this Freedom Tech submission. Respond with ONLY valid JSON.\\n\\nSubmission: {{ $('Insert Submission').first().json.message }}\\n\\nJSON format:\\n{\\\"tags\\\": [\\\"2-4 relevant tags\\\"], \\\"risk_level\\\": \\\"low|medium|high\\\", \\\"summary\\\": \\\"brief title for GitHub issue\\\"}\"\n  }]\n}",
        "options": {}
