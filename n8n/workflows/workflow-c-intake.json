      "id": "8d4a91f3-2fb2-4be9-9d5f-0bc2ebc6a3be",
      "name": "Classify with Claude"
    },
    {
      "parameters": {
        "jsCode": "const message = $('Insert Submission').first().json.message;\n\n// Simple keyword-based classification for testing\nconst tags = [];\nif (message.toLowerCase().includes('messaging') || message.toLowerCase().includes('comms')) tags.push('comms');\nif (message.toLowerCase().includes('offline')) tags.push('censorship-resistance');\nif (message.toLowerCase().includes('secure') || message.toLowerCase().includes('privacy')) tags.push('privacy');\nif (tags.length === 0) tags.push('general');\n\nconst result = {\n  tags,\n  risk_level: 'low',\n  summary: message.substring(0, 50) + '...'\n};\n\n// Match Claude API response format\nreturn [{\n  json: {\n    content: [{\n      type: 'text',\n      text: JSON.stringify(result)\n    }]\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        208,
        32
      ],
      "id": "b0d80e32-5e56-4553-8037-9011a2c680f1",
      "name": "Classify Stub"
    },
    {
      "parameters": {
        "jsCode": "const content = $input.first().json.content[0].text;\nconst parsed = JSON.parse(content);\nconst submissionId = $('Insert Submission').first().json.id;\nconst message = $('Insert Submission').first().json.message;\n\nreturn [{ json: { ...parsed, submissionId, message } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        416,
        32
      ],
      "id": "2c3ce832-b8bc-4645-a849-4d340ec89943",
      "name": "Parse LLM Response"
    },
