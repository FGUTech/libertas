{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://libertas.fgu.tech/schemas/source-item.schema.json",
  "title": "SourceItem",
  "description": "Represents a single piece of fetched content from any source",
  "type": "object",
  "required": ["id", "url", "platform", "fetchedAt", "extractedText", "contentHash", "createdAt", "updatedAt"],
  "properties": {
    "id": {
      "type": "string",
      "format": "uuid",
      "description": "UUIDv4 identifier"
    },
    "url": {
      "type": "string",
      "format": "uri",
      "description": "Canonical source URL"
    },
    "platform": {
      "type": "string",
      "enum": ["rss", "web", "x", "nostr", "github", "email"],
      "description": "Source platform type"
    },
    "fetchedAt": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 UTC timestamp of when content was fetched"
    },
    "rawContentRef": {
      "type": "string",
      "description": "Object storage key for raw content"
    },
    "extractedText": {
      "type": "string",
      "description": "Cleaned text content extracted from source"
    },
    "contentHash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$",
      "description": "SHA-256 hash of extractedText"
    },
    "author": {
      "type": "string",
      "description": "Author name if available"
    },
    "accountHandle": {
      "type": "string",
      "description": "@handle if social platform"
    },
    "publishedAt": {
      "type": "string",
      "format": "date-time",
      "description": "Original publish date if known"
    },
    "language": {
      "type": "string",
      "pattern": "^[a-z]{2}$",
      "description": "ISO 639-1 language code"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true,
      "description": "Platform-specific metadata"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time",
      "description": "Record creation timestamp"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time",
      "description": "Last update timestamp"
    }
  }
}
