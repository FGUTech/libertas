{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://libertas.fgu.tech/schemas/llm-outputs/digest-result.schema.json",
  "title": "DigestResult",
  "description": "LLM output schema for weekly digest composition",
  "type": "object",
  "required": ["executive_tldr", "sections", "insight_count"],
  "properties": {
    "executive_tldr": {
      "type": "string",
      "maxLength": 500,
      "description": "2-3 sentence executive summary of the week"
    },
    "sections": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["title", "content_markdown"],
        "properties": {
          "title": {
            "type": "string",
            "description": "Section title (e.g., 'Bitcoin & Payments')"
          },
          "content_markdown": {
            "type": "string",
            "description": "Section content in markdown"
          },
          "insight_ids": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "IDs of insights included in this section"
          }
        }
      },
      "description": "Digest sections grouped by topic"
    },
    "emerging_patterns": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "pattern": {
            "type": "string",
            "description": "Description of the emerging pattern"
          },
          "supporting_signals": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Insight IDs supporting this pattern"
          }
        }
      },
      "description": "Cross-signal trend analysis"
    },
    "looking_ahead": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "What to monitor next week"
    },
    "insight_count": {
      "type": "integer",
      "minimum": 0,
      "description": "Total number of insights in this digest"
    },
    "top_topics": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Most prominent topics this week"
    }
  }
}
