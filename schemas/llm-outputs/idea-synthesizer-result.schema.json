{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://libertas.fgu.tech/schemas/llm-outputs/idea-synthesizer-result.schema.json",
  "title": "IdeaSynthesizerResult",
  "description": "LLM output schema for project idea generation",
  "type": "object",
  "required": ["problem_statement", "threat_model", "affected_groups", "proposed_solution", "mvp_scope", "misuse_risks", "feasibility_score", "impact_score"],
  "properties": {
    "problem_statement": {
      "type": "string",
      "minLength": 50,
      "maxLength": 500,
      "description": "Clear, specific problem grounded in source material"
    },
    "threat_model": {
      "type": "string",
      "minLength": 50,
      "maxLength": 500,
      "description": "Who is the adversary and their capabilities"
    },
    "affected_groups": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1,
      "description": "Who would benefit from a solution"
    },
    "proposed_solution": {
      "type": "string",
      "minLength": 100,
      "maxLength": 1000,
      "description": "Technical approach at a high level"
    },
    "mvp_scope": {
      "type": "string",
      "minLength": 50,
      "maxLength": 500,
      "description": "Minimum viable version buildable in weeks"
    },
    "misuse_risks": {
      "type": "string",
      "minLength": 50,
      "maxLength": 500,
      "description": "How could this be misused and by whom"
    },
    "feasibility_score": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100,
      "description": "Technical feasibility (0-100)"
    },
    "impact_score": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100,
      "description": "Potential impact (0-100)"
    },
    "technical_dependencies": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Required technical dependencies"
    },
    "suggested_stack": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Recommended technology stack"
    },
    "prior_art": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Existing projects to learn from"
    },
    "open_questions": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Unresolved questions requiring research"
    }
  }
}
